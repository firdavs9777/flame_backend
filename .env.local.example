# Local development environment
# Copy this to .env.local and fill in real values. .env.local is gitignored.

# App
DEBUG=True
APP_NAME=Flame API
APP_VERSION=1.0.0

# MongoDB — copy from prod .env on EC2, change the database name to flame_db_dev
# Format: mongodb://<user>:<password>@<host>:27017,.../flame_db_dev?ssl=true&...
MONGODB_URL=
MONGODB_DB_NAME=flame_db_dev

# JWT — local-only secret, never used in production
JWT_SECRET_KEY=local-dev-secret-not-for-production-use-32bytes-min-padding-padding
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis — Docker service name from docker-compose.dev.yml
REDIS_URL=redis://redis:6379

# CORS — allow local frontend dev servers
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# Rate Limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
RATE_LIMIT_API=100

# Photo Upload
MAX_PHOTO_SIZE=10485760
ALLOWED_PHOTO_TYPES=["image/jpeg","image/png","image/webp"]
MAX_PHOTOS_PER_USER=6

# DigitalOcean Spaces — same as prod, just a different folder
DO_SPACES_KEY=
DO_SPACES_SECRET=
SPACES_BUCKET=my-projects-media
SPACES_REGION=sfo3
SPACES_ENDPOINT=sfo3.digitaloceanspaces.com
SPACES_CDN_URL=https://my-projects-media.sfo3.cdn.digitaloceanspaces.com
SPACES_PROJECT_FOLDER=flame_backend_dev

# Email — fill in only if testing email flows
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us
FROM_NAME=Flame Dev
FROM_EMAIL=dev@flame.local
SENDGRID_API_KEY=

# Social Auth — fill in from your Google/Apple/Facebook developer consoles
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Firebase
FIREBASE_PROJECT_ID=
